# =============================================================================
# GLOC — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
/target/
Cargo.lock
# Cargo.lock is committed for binaries (examples); omit for libraries if preferred
# Cargo.lock

# Compiled artifacts that may appear in subcrates
**/target/

# Cargo config secrets (never commit tokens or registry credentials)
.cargo/credentials
.cargo/credentials.toml

# -----------------------------------------------------------------------------
# Claude Code
# -----------------------------------------------------------------------------
.claude/
GLOC_ROADMAP.md

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
**/.DS_Store

# -----------------------------------------------------------------------------
# IDEs — JetBrains (RustRover, IntelliJ, CLion)
# -----------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws

# -----------------------------------------------------------------------------
# IDEs — VS Code
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json   # allow sharing recommended extensions

# -----------------------------------------------------------------------------
# IDEs — other
# -----------------------------------------------------------------------------
.fleet/
*.sublime-project
*.sublime-workspace
.zed/

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# OS / system
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs & temp files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Benchmark / profiling artefacts
# -----------------------------------------------------------------------------
perf.data
perf.data.old
flamegraph.svg
criterion/

# -----------------------------------------------------------------------------
# Test output artefacts
# -----------------------------------------------------------------------------
# trybuild generates these during overwrite mode — they are committed snapshots
# so do NOT ignore *.stderr inside tests/ui/fail/
# But ignore any stray output outside the canonical snapshot directories
/gloc-macro/tests/ui/**/*.stderr.bak
