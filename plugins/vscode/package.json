{
  "name": "gloc-vscode",
  "displayName": "GLoC Reactor Generator",
  "description": "Generate GLoC reactor files from the Explorer context menu",
  "version": "0.1.0",
  "publisher": "GodwinJoseph",
  "icon": "media/gloc_icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/godwinjk/GLoC.git",
    "directory": "plugins/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],

  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gloc.newReactor",
        "title": "New Reactor"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "gloc.newReactor",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "ovsx": "^1.0.0",
    "typescript": "^5.3.0"
  }
}
