{
  "name": "gloc-vscode",
  "displayName": "GLoC Reactor Generator",
  "description": "Generate GLoC reactor files from the Explorer context menu",
  "version": "0.1.0",
  "publisher": "gloc",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:gloc.newReactor"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gloc.newReactor",
        "title": "New GLoC Reactor"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "gloc.newReactor",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0"
  }
}
