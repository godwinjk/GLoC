<idea-plugin>
  <id>com.gloc.plugin</id>
  <vendor email="godwinjose.k@gmail.com" url="https://github.com/godwinjk/GLoC">Godwin Joseph</vendor>

  <!-- name, version, vendor, description, change-notes, and idea-version
       are all injected by the patchPluginXml Gradle task from gradle.properties,
       README.md, and CHANGELOG.md. Do not add them here. -->

  <depends>com.intellij.modules.platform</depends>
  <depends>com.jetbrains.rust</depends>

  <actions>
    <action
      id="GlocNewReactorAction"
      class="com.gloc.plugin.GlocNewReactorAction"
      text="GLoC Reactor"
      description="Create a new GLoC Reactor file"
      icon="/icon/gloc_icon_16.svg">
      <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewDir"/>
    </action>
  </actions>
</idea-plugin>
